---
interface FunctionMeta {
	title: string;
	description: string;
	topic: string;
	signature: string;
	version: string;
}

interface FunctionEntry {
	data: FunctionMeta;
	slug: string;
}

interface Props {
	entry: FunctionEntry;
	allFunctions: FunctionEntry[];
	version: string;
	func: string;
}

import FunctionTOC from "./FunctionTOC.astro";
import { versions } from "../config/versions";
import type { VersionSlug } from "../config/versions";

const { entry, allFunctions, version, func } = Astro.props as Props;

const versionLabel = versions[version as VersionSlug]?.label ?? version;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
	<ol>
		<li><a href={`/functions/${version}/`}>Functions</a></li>
		<li aria-hidden="true">›</li>
		<li><a href={`/functions/${version}/`}>{versionLabel}</a></li>
		<li aria-hidden="true">›</li>
		<li aria-current="page">{entry.data.title}</li>
	</ol>
</nav>

<div class="func-page">
	<FunctionTOC functions={allFunctions} currentFunc={func} version={version} />

	<article class="func-content">
		<div class="func-meta">
			<span class="func-topic">{entry.data.topic}</span>
			<span class="func-version">{versionLabel}</span>
		</div>
		<h1>{entry.data.title}</h1>
		<p class="func-description">{entry.data.description}</p>
		<pre class="func-signature"><code>{entry.data.signature}</code></pre>
		<div class="func-body">
			<slot />
		</div>
	</article>
</div>

<style>
	.breadcrumb {
		margin-bottom: 1rem;
		font-size: 0.85rem;
		color: #666;
	}
	.breadcrumb ol {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
	}
	.breadcrumb li[aria-hidden] {
		color: #bbb;
	}
	.breadcrumb a {
		color: #1565c0;
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}
	.breadcrumb [aria-current="page"] {
		color: #333;
		font-weight: 500;
	}

	.func-page {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	/* ── Content ── */
	.func-content {
		flex: 1;
		min-width: 0;
		line-height: 1.7;
	}

	.func-meta {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.func-topic,
	.func-version {
		font-size: 0.75rem;
		padding: 0.15rem 0.5rem;
		border-radius: 3px;
		background: #e8eaf6;
		color: #3949ab;
		font-weight: 500;
	}

	.func-content h1 {
		margin-top: 0;
		font-size: 2rem;
		color: #1a1a2e;
	}

	.func-description {
		color: #555;
		font-size: 1.05rem;
		margin: 0.5rem 0 1rem;
	}

	.func-signature {
		background: #1e1e2e;
		border-radius: 6px;
		padding: 0.75rem 1.25rem;
		margin: 0 0 1.5rem;
		overflow-x: auto;
	}

	.func-signature code {
		color: #cdd6f4;
		font-family: "Fira Code", "Consolas", "Monaco", monospace;
		font-size: 0.9rem;
	}

	.func-body :global(h2) {
		margin-top: 2rem;
		margin-bottom: 0.5rem;
		color: #1a1a2e;
		font-size: 1.4rem;
		border-bottom: 1px solid #e0e0e0;
		padding-bottom: 0.25rem;
	}

	.func-body :global(h3) {
		margin-top: 1.5rem;
		margin-bottom: 0.4rem;
		color: #1a1a2e;
		font-size: 1.1rem;
	}

	.func-body :global(p) {
		margin: 0.6rem 0 1rem;
	}

	.func-body :global(ul),
	.func-body :global(ol) {
		padding-left: 1.5rem;
		margin: 0.5rem 0 1rem;
	}

	.func-body :global(li) {
		margin: 0.25rem 0;
	}

	.func-body :global(code) {
		background: #f0f0f0;
		padding: 0.1em 0.35em;
		border-radius: 3px;
		font-size: 0.9em;
		font-family: "Fira Code", "Consolas", "Monaco", monospace;
	}

	.func-body :global(pre) {
		background: #f5f5f5;
		border: 1px solid #e0e0e0;
		border-radius: 6px;
		padding: 1rem 1.25rem;
		overflow-x: auto;
		margin: 0.75rem 0 1.25rem;
	}

	.func-body :global(pre code) {
		background: none;
		padding: 0;
		font-size: 0.875rem;
		line-height: 1.6;
	}

	/* Syntax highlighting styles for code blocks */
	.func-body :global(.language-json),
	.func-body :global(.language-jmespath),
	.func-body :global(.language-code) {
		/* Colors are applied via inline styles in highlighted spans */
	}

	/* JSON syntax highlighting colors (from highlightJSON) */
	.func-body :global(.json-key) {
		color: #89b4fa; /* Blue */
	}

	.func-body :global(.json-string) {
		color: #a6e3a1; /* Green */
	}

	.func-body :global(.json-number),
	.func-body :global(.json-boolean),
	.func-body :global(.json-null) {
		color: #f5c2de; /* Pink */
	}

	.func-body :global(.json-punctuation) {
		color: #6c7086; /* Gray */
	}

	.func-body :global(table) {
		border-collapse: collapse;
		width: 100%;
		margin: 1rem 0;
		font-size: 0.9rem;
	}

	.func-body :global(th),
	.func-body :global(td) {
		border: 1px solid #e0e0e0;
		padding: 0.5rem 0.75rem;
		text-align: left;
	}

	.func-body :global(th) {
		background: #f5f5f5;
		font-weight: 600;
	}

	.func-body :global(a) {
		color: #1565c0;
		text-decoration: none;
	}

	.func-body :global(a:hover) {
		text-decoration: underline;
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.func-page {
			flex-direction: column;
		}
	}
</style>
