---
interface FunctionEntry {
	data: {
		title: string;
	};
	slug: string;
}

interface Props {
	functions: FunctionEntry[];
	currentFunc: string;
	version: string;
}

const { functions, currentFunc, version } = Astro.props;

const sortedFunctions = [...functions].sort((a, b) =>
	a.data.title.localeCompare(b.data.title),
);
---

<aside class="func-toc" aria-label="Function list">
	<h2>Functions</h2>
	<nav>
		<ul>
			{
				sortedFunctions.map((f) => {
					const fname = f.slug.split("/").at(-1) ?? f.slug;
					const isActive = fname === currentFunc;
					return (
						<li>
							<a
								href={`/functions/${version}/${fname}/`}
								aria-current={isActive ? "page" : undefined}
								class:list={[{ active: isActive }]}
							>
								{f.data.title}
							</a>
						</li>
					);
				})
			}
		</ul>
	</nav>
</aside>

<style>
	.func-toc {
		flex: 0 0 220px;
		position: sticky;
		top: 4.5rem;
		max-height: calc(100vh - 5rem);
		overflow-y: auto;
		padding: 1rem;
		background: #f8f9fa;
		border-radius: 6px;
		border: 1px solid #e0e0e0;
		font-size: 0.85rem;
	}

	.func-toc h2 {
		margin: 0 0 0.75rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #555;
	}

	.func-toc nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.func-toc nav a {
		display: block;
		color: #333;
		text-decoration: none;
		padding: 0.2rem 0.4rem;
		border-radius: 3px;
		line-height: 1.4;
		word-break: break-word;
	}

	.func-toc nav a:hover {
		background: #e8eaf6;
		color: #1a237e;
	}

	.func-toc nav a.active {
		background: #e3f2fd;
		color: #1565c0;
		font-weight: 600;
	}

	@media (max-width: 900px) {
		.func-toc {
			position: static;
			flex: none;
			width: 100%;
			max-height: 280px;
		}
	}
</style>
